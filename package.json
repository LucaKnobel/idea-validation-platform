{
  "name": "idea-validation-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "start:prod": "node .output/server/index.mjs",
    "start:migrate": "npx prisma migrate deploy && npm run start:prod",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && [ -d .git ] && git config core.hooksPath .githooks || true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "test:e2e": "nuxt build && vitest run --project e2e",
    "test:coverage": "nuxt build && vitest run --coverage --coverage.provider=v8 --coverage.all=true --coverage.reporter=text --coverage.reporter=html --coverage.reporter=json-summary --coverage.reporter=lcov",
    "test:coverage:unit": "vitest run --project unit --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html --coverage.reporter=json-summary --coverage.reporter=lcov",
    "test:coverage:e2e": "nuxt build && vitest run --project e2e --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "test:coverage:backend": "nuxt build && vitest run --project unit --project e2e --coverage --coverage.provider=v8 --coverage.all=true --coverage.include=server/**/*.ts --coverage.exclude=server/**/*.d.ts --coverage.reporter=text --coverage.reporter=html --coverage.reporter=json-summary --coverage.reporter=lcov"
  },
  "dependencies": {
    "@iconify-json/lucide": "1.2.107",
    "@iconify-json/simple-icons": "1.2.82",
    "@nuxt/content": "3.13.0",
    "@nuxt/ui": "4.7.1",
    "@nuxtjs/i18n": "10.3.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "better-auth": "1.6.11",
    "better-sqlite3": "12.10.0",
    "dotenv": "17.4.2",
    "nodemailer": "8.0.7",
    "nuxt": "4.4.5",
    "nuxt-security": "2.6.0",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@types/nodemailer": "8.0.0",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.6",
    "@vue/test-utils": "2.4.10",
    "eslint": "10.3.0",
    "happy-dom": "20.9.0",
    "playwright-core": "1.60.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6",
    "vue-tsc": "3.2.8"
  },
  "overrides": {
    "devalue": "5.8.1"
  }
}
