    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "better-auth": "^1.6.9",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "nodemailer": "^8.0.7",
    "nuxt": "^4.4.2",
    "nuxt-security": "^2.5.1",
    "pg": "^8.20.0",
