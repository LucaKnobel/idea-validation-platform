{
  "name": "idea-validation-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "scripts": {
    "start:prod": "node .output/server/index.mjs",
    "start:migrate": "npx prisma migrate deploy && npm run start:prod",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && [ -d .git ] && git config core.hooksPath .githooks || true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:nuxt": "vitest run --project nuxt",
    "test:e2e": "nuxt build && vitest run --project e2e"
  },
  "dependencies": {
    "@iconify-json/lucide": "1.2.111",
    "@iconify-json/simple-icons": "1.2.86",
    "@nuxt/content": "3.14.0",
    "@nuxt/ui": "4.8.2",
    "@nuxtjs/i18n": "10.4.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "better-auth": "1.6.11",
    "better-sqlite3": "12.10.0",
    "dotenv": "17.4.2",
    "nodemailer": "8.0.11",
    "nuxt": "4.4.8",
    "nuxt-security": "2.6.0",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "1.16.0",
    "@nuxt/test-utils": "4.0.3",
    "@types/nodemailer": "8.0.1",
    "@types/pg": "8.20.0",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.4.1",
    "happy-dom": "20.10.2",
    "playwright-core": "1.60.0",
    "typescript": "6.0.3",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  },
  "overrides": {
    "devalue": "5.8.1"
  }
}
