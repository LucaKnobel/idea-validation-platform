// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Better Auth standard model
model User {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  subscription  Subscription? // not Better Auth standard
  ideas         Idea[] // not Better Auth standard

  @@unique([email])
  @@map("user")
}

// Better Auth standard model
model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

// Better Auth standard model
model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

// Better Auth standard model
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Better Auth standard model
model RateLimit {
  id          String @id
  key         String @unique
  count       Int
  lastRequest BigInt

  @@map("rateLimit")
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
}

model Subscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan              SubscriptionPlan
  status            SubscriptionStatus
  providerReference String?
  currentPeriodEnd  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("subscription")
}

model Idea {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions  IdeaVersion[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@map("idea")
}

enum IdeaVersionType {
  INITIAL
  ITERATION
  PIVOT
}

enum CanvasElementType {
  CUSTOMER_SEGMENTS
  VALUE_PROPOSITIONS
  CHANNELS
  CUSTOMER_RELATIONSHIPS
  REVENUE_STREAMS
  KEY_RESOURCES
  KEY_ACTIVITIES
  KEY_PARTNERS
  COST_STRUCTURE
}

enum HypothesisDimension {
  PROBLEM
  SOLUTION
  MARKET
  MONETIZATION
  EXECUTION
}

enum HypothesisPriority {
  HIGH
  MEDIUM
  LOW
}

enum HypothesisStatus {
  NOT_TESTED
  VALIDATED
  INVALIDATED
}

enum ExperimentStatus {
  PLANNED
  RUNNING
  COMPLETED
  CANCELLED
}

enum EvidenceType {
  QUALITATIVE
  QUANTITATIVE
  BEHAVIORAL
  MONETARY
}

enum ThresholdOperator {
  GTE
  GT
  LTE
  LT
  EQ
}

model IdeaVersion {
  id             String          @id @default(uuid())
  ideaId         String
  idea           Idea            @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  canvasElements CanvasElement[]
  hypotheses     Hypothesis[]
  versionNumber  Int
  type           IdeaVersionType
  title          String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([ideaId, versionNumber])
  @@index([ideaId])
  @@map("ideaVersion")
}

model Hypothesis {
  id                 String                    @id @default(uuid())
  ideaVersionId      String
  ideaVersion        IdeaVersion               @relation(fields: [ideaVersionId], references: [id], onDelete: Cascade)
  statement          String
  dimension          HypothesisDimension
  priority           HypothesisPriority
  evidenceType       EvidenceType
  status             HypothesisStatus          @default(NOT_TESTED)
  canvasSectionLinks HypothesisCanvasSection[]
  metric             Metric?
  experiment         Experiment?
  measurement        Measurement?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@index([ideaVersionId])
  @@map("hypothesis")
}

model HypothesisCanvasSection {
  id                String            @id @default(uuid())
  hypothesisId      String
  hypothesis        Hypothesis        @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  canvasElementType CanvasElementType
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([hypothesisId, canvasElementType])
  @@index([canvasElementType])
  @@map("hypothesisCanvasSection")
}

model CanvasElement {
  id            String            @id @default(uuid())
  ideaVersionId String
  ideaVersion   IdeaVersion       @relation(fields: [ideaVersionId], references: [id], onDelete: Cascade)
  type          CanvasElementType
  content       String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([ideaVersionId])
  @@index([ideaVersionId, type])
  @@map("canvasElement")
}

model Metric {
  id           String           @id @default(uuid())
  hypothesisId String
  hypothesis   Hypothesis       @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  unit         String?
  threshold    MetricThreshold?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([hypothesisId])
  @@map("metric")
}

model Experiment {
  id           String           @id @default(uuid())
  hypothesisId String
  hypothesis   Hypothesis       @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       ExperimentStatus
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([hypothesisId])
  @@map("experiment")
}

model Measurement {
  id           String     @id @default(uuid())
  hypothesisId String     @unique
  hypothesis   Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  value        Decimal
  note         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("measurement")
}

model MetricThreshold {
  id             String            @id @default(uuid())
  metricId       String            @unique
  metric         Metric            @relation(fields: [metricId], references: [id], onDelete: Cascade)
  operator       ThresholdOperator
  referenceValue Decimal
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@map("metricThreshold")
}
